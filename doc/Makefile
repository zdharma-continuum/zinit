# This Makefile is to convert supplied Asciidoc files into other formats like
# pdf and man. The files contain Zplugin's code documentation.
#
# *.adoc files are generated by Makefile from upper (i.e. top) directory.

ZSH := /Users/null/.local/bin/zsh
DIRS=man pdf data
$(shell mkdir -p $(DIRS))

SRC := zinit.zsh zinit-side.zsh zinit-install.zsh zinit-autoload.zsh zinit-additional.zsh
DOC_SRC := $(foreach wrd,$(SRC),$(shell git rev-parse --show-toplevel)/$(wrd))
ASCIIDOC_SRC := $(foreach wrd,$(SRC),$(wrd).adoc)
.PHONY: all
all: man pdf asciidoc

MAN_CMD := a2x --verbose -L --doctype manpage --format manpage -D man
PDF_CMD := asciidoctor -a reproducible -b pdf -r asciidoctor-pdf -D pdf
ASCIIDOC_CMD := "zsd -v --scomm --cignore '(\#*FUNCTION:*{{{*|\#[[:space:]]#}}}*)'"

.PHONY: asciidoc
asciidoc: clean
	$(ZSH) -dfic "zsd -v --scomm --cignore '(\#*FUNCTION:*{{{*|\#[[:space:]]#}}}*)' $(DOC_SRC)"

#
# Manuals (man pages) -- converted with a2x from asciidoc package
#

.PHONY: man
man: zinit.zsh.1 zinit-side.zsh.1 zinit-install.zsh.1 zinit-autoload.zsh.1 zinit-additional.zsh.1
# man: $(foreach wrd,$(SRC),$(wrd).1)

zinit.zsh.1:
	$(MAN_CMD) zsdoc/zinit.zsh.adoc

zinit-side.zsh.1:
	$(MAN_CMD) zsdoc/zinit-side.zsh.adoc

zinit-install.zsh.1:
	$(MAN_CMD) zsdoc/zinit-install.zsh.adoc

zinit-autoload.zsh.1:
	$(MAN_CMD) zsdoc/zinit-autoload.zsh.adoc

zinit-additional.zsh.1:
	$(MAN_CMD) zsdoc/zinit-additional.zsh.adoc

#
# PDFs -- uses asciidoctor (i.e., not asciidoc)
#

.PHONY: pdf
pdf: zinit.zsh.pdf zinit-side.zsh.pdf zinit-install.zsh.pdf zinit-autoload.zsh.pdf zinit-additional.zsh.1

zinit.zsh.pdf:
	$(PDF_CMD) zinit.zsh.adoc

zinit-side.zsh.pdf:
	$(PDF_CMD) zinit-side.zsh.adoc

zinit-install.zsh.pdf:
	$(PDF_CMD) zinit-install.zsh.adoc

zinit-autoload.zsh.pdf:
	$(PDF_CMD) zinit-autoload.zsh.adoc

.PHONY: clean
clean:
	rm -rf $(DIRS)

.PHONY: test
test:
	@$(error --- NOT IMPLEMENTED)

